# ── Design references (not for version control) ──────────────────────────────
Stitch/

# ── Frontend ──────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── Backend ───────────────────────────────────────────────────────────────────
backend/.env
backend/__pycache__/
backend/src/__pycache__/
backend/src/models/__pycache__/
backend/src/routers/__pycache__/
backend/.venv/
*.pyc
*.pyo
*.pyd

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────────────────────────────────────
*.local
.env
.env.*
!.env.example
